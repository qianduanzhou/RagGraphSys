# 前端镜像打包配置
# 使用：复制为 .env，按需修改后执行 npm run image:build 或 npm run image:push

# 镜像仓库登录地址，例如 registry.cn-hangzhou.aliyuncs.com
REGISTRY_ADDRESS=registry.example.com
REGISTRY_USERNAME=your_registry_username
REGISTRY_PASSWORD=your_registry_password

# 镜像名称与标签
IMAGE_NAME=rag-graph-frontend
IMAGE_TAG=latest

# 镜像推送仓库前缀（不含镜像名和 tag），例如 registry.example.com/team
IMAGE_PUSH_ADDRESS=registry.example.com/team

# 部署机前端访问端口
FRONTEND_PORT=7847


# 后端镜像打包配置
# 使用：复制为 .env，按需修改后执行 python script/build_image.py

# 镜像仓库登录地址，例如 registry.cn-hangzhou.aliyuncs.com
REGISTRY_ADDRESS=registry.example.com
REGISTRY_USERNAME=your_registry_username
REGISTRY_PASSWORD=your_registry_password

# 镜像名称与标签
IMAGE_NAME=rag-graph-backend
IMAGE_TAG=latest

# 镜像推送仓库前缀（不含镜像名和 tag），例如 registry.example.com/team
IMAGE_PUSH_ADDRESS=registry.example.com/team

# ---- 运行时配置：docker-compose.yaml 也会读取本文件 ----
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-5.2
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSION=2048
LLM_REQUEST_TIMEOUT=60
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=2048

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_documents
QDRANT_TOP_K=5

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ChangeMe12345

TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5

CHUNK_SIZE=500
CHUNK_OVERLAP=80
MAX_REFLECTION_ITERATIONS=2
APP_HOST=0.0.0.0
APP_PORT=8000
BACKEND_PORT=7846
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
LOG_LEVEL=INFO

# 本地账号与 Token 存储文件；默认本地为 backend/data/users.json，容器内为 /app/data/users.json
# AUTH_DB_PATH=./data/users.json




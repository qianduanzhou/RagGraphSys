# =============================================================
#  LLM / Embedding（OpenAI 兼容）
#  任意 OpenAI 兼容接口：智谱 / OpenAI / DeepSeek / 本地 vLLM 等，
#  配好 base_url 与 api_key 即可。
# =============================================================
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-5.2
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSION=2048
LLM_REQUEST_TIMEOUT=60
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=2048

# =============================================================
#  Qdrant（向量数据库）
# =============================================================
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_documents
QDRANT_TOP_K=5

# =============================================================
#  Neo4j（图数据库）
#  注意：Neo4j 5.x 强制要求密码至少 8 位。
#  如果启动时鉴权失败，请将这里的 NEO4J_PASSWORD 改为 >=8 位，
#  并同步修改 docker-compose.yaml 中的 NEO4J_AUTH，使其保持一致。
# =============================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=123456

# ---- 联网搜索（Tavily） ----
# 多智能体模式需要；留空则联网智能体自动降级。免费额度：https://tavily.com
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5

# =============================================================
#  RAG 流水线调参
# =============================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=80
MAX_REFLECTION_ITERATIONS=2

# =============================================================
#  应用服务器
# =============================================================
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
LOG_LEVEL=INFO

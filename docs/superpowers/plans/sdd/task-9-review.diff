+
+/* === Task 9：多智能体模式相关样式（追加，不覆盖既有） === */
+
+/* 模式切换控件（ChatWindow 已有 .mode-switch，补配套样式） */
+.mode-switch {
+  display: inline-flex;
+  gap: 0;
+  border: 1px solid var(--border, #d0d7de);
+  border-radius: 8px;
+  overflow: hidden;
+  margin-bottom: 8px;
+}
+.mode-switch button {
+  padding: 6px 14px;
+  border: none;
+  background: transparent;
+  cursor: pointer;
+  font-size: 13px;
+  color: inherit;
+}
+.mode-switch button.active {
+  background: var(--accent, #2563eb);
+  color: #fff;
+}
+.mode-switch button:disabled {
+  opacity: 0.45;
+  cursor: not-allowed;
+}
+
+/* web 来源徽章：渲染为可点击链接 */
+.source-badge.web {
+  color: var(--link, #2563eb);
+  text-decoration: none;
+  border: 1px solid var(--border, #d0d7de);
+  border-radius: 6px;
+  padding: 2px 8px;
+  font-size: 12px;
+  align-self: flex-start;
+}
+.source-badge.web:hover {
+  background: rgba(37, 99, 235, 0.08);
+}
+
+/* 多智能体原始回答折叠面板 */
+.agent-panels {
+  margin-top: 10px;
+  display: flex;
+  flex-direction: column;
+  gap: 6px;
+}
+.agent-panel {
+  border: 1px solid var(--border, #d0d7de);
+  border-radius: 6px;
+  padding: 6px 10px;
+  font-size: 13px;
+}
+.agent-panel summary {
+  cursor: pointer;
+  color: var(--muted, #57606a);
+  user-select: none;
+}
+.agent-panel-body {
+  margin-top: 6px;
+  padding-top: 6px;
+  border-top: 1px dashed var(--border, #d0d7de);
+  white-space: pre-wrap;
+  line-height: 1.6;
+}
